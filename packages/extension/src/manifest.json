{
  "manifest_version": 3,
  "name": "Val OpenAI Local Bridge",
  "description": "Relays an authenticated RMIT Val session to a loopback OpenAI-compatible companion.",
  "version": "0.1.3",
  "minimum_chrome_version": "116",
  "permissions": ["storage"],
  "host_permissions": ["https://val.rmit.edu.au/*", "http://127.0.0.1/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Val OpenAI Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://val.rmit.edu.au/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
